norm_minmax <- function(x) {
  (x - min(x, na.rm = TRUE)) / (max(x, na.rm = TRUE) - min(x, na.rm = TRUE))
}

norm_minmax_inv <- function(x) {
  1 - norm_minmax(x)
}

var_Positive <- c("EDU", "WAS", "URB", "TEC")
var_negative <- c("RAI", "HIG", "AIR", "POR")


Accessibility_ <- Accessibility_ %>%
  mutate(
    across(all_of(var_Positive), ~ . / 100),                
    across(all_of(var_negative), norm_minmax_inv),          
    INC = norm_minmax(INC)                           
  )


Accessibility_$REG <- as.factor(Accessibility_$REG)
 

OLS <- lm(
  INC ~ EDU + WAS + URB + TEC +
