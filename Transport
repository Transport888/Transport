# (n.d. ,2023)

pseudo_R2 <- sapply(taus, function(tau) {

  fit0 <- rq(INC ~ 1, tau = tau, data = Accessibility_)
  

  fit1 <- rq(INC ~ EDU + WAS + URB + TEC +
               RAI + HIG + AIR + POR + REG + POP,
             tau = tau, data = Accessibility_)
  

  1 - fit1$rho / fit0$rho
})

names(pseudo_R2) <- paste0("tau_", taus)


sumQR         
pseudo_R2     

library(quantreg)
set.seed(123)

taus <- c(0.1, 0.25, 0.5, 0.75, 0.9)
results <- list()

for(t in taus){
  QR <- rq(INC ~ EDU + WAS + URB + TEC + RAI + HIG + AIR + POR + REG + POP, tau = t, data = Accessibility_)
  sum_QR <- summary(QR, se = "boot", R = 1000) 
  coef_table <- data.frame(
    Variable = rownames(sum_QR$coefficients),
    Estimate = sum_QR$coefficients[, "Value"],
    Std.Error = sum_QR$coefficients[, "Std. Error"],
    t.value = sum_QR$coefficients[, "t value"],
    p.value = sum_QR$coefficients[, "Pr(>|t|)"],
    Tau = t
  )
  results[[as.character(t)]] <- coef_table
}

QR_table


